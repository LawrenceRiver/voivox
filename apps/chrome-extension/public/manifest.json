{
  "manifest_version": 3,
  "name": "VOIVOX Tab Capture",
  "description": "Silently send the active Chrome tab's audio to your local VOIVOX desktop app.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "VOIVOX"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "permissions": ["activeTab", "offscreen", "storage", "tabCapture"],
  "host_permissions": ["http://127.0.0.1/*"]
}
